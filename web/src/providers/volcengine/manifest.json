{
  "id": "volcengine",
  "name": "火山方舟 (Volcengine)",
  "version": "0.1.0",
  "description": "火山方舟视频生成 Provider，支持 Seedance 视频生成。",
  "responseMode": "async-pollable",
  "capabilities": ["video"],
  "auth": {
    "fields": [
      { "key": "baseUrl", "type": "string", "label": "Base URL", "placeholder": "https://ark.cn-beijing.volces.com/api/v3", "required": true },
      { "key": "apiKey", "type": "password", "label": "API Key", "placeholder": "volcengine api key", "required": true }
    ]
  },
  "allowsCustomModels": true,
  "models": [
    {
      "id": "doubao-seedance-2-0-260128",
      "name": "Seedance 2.0（推荐）",
      "description": "主流视频生成模型，支持参考图、参考视频和音频。",
      "capabilities": ["video"],
      "supportsReferenceImages": true,
      "supportsReferenceVideos": true,
      "supportsReferenceAudios": true
    },
    {
      "id": "doubao-seedance-2-0-fast-260128",
      "name": "Seedance 2.0 Fast",
      "description": "更快的视频生成模型，支持参考图、参考视频和音频。",
      "capabilities": ["video"],
      "supportsReferenceImages": true,
      "supportsReferenceVideos": true,
      "supportsReferenceAudios": true
    },
    {
      "id": "doubao-seedance-1-5-pro-250428",
      "name": "Seedance 1.5 Pro",
      "description": "支持参考图、参考视频和音频。",
      "capabilities": ["video"],
      "supportsReferenceImages": true,
      "supportsReferenceVideos": true,
      "supportsReferenceAudios": true
    },
    {
      "id": "doubao-seedance-1-5-lite-250428",
      "name": "Seedance 1.5 Lite",
      "description": "轻量视频生成模型，支持参考图。",
      "capabilities": ["video"],
      "supportsReferenceImages": true,
      "supportsReferenceVideos": false,
      "supportsReferenceAudios": false
    },
    {
      "id": "doubao-seedance-1-0-pro-250528",
      "name": "Seedance 1.0 Pro",
      "description": "支持参考图的视频生成模型。",
      "capabilities": ["video"],
      "supportsReferenceImages": true,
      "supportsReferenceVideos": false,
      "supportsReferenceAudios": false
    }
  ],
  "parameterSchemas": {
    "video": {
      "type": "object",
      "properties": {
        "baseUrl": { "type": "string" },
        "apiKey": { "type": "string" },
        "model": { "type": "string" },
        "prompt": { "type": "string" },
        "ratio": { "type": "string", "enum": ["16:9", "9:16", "1:1", "4:3", "3:4", "21:9", "adaptive"] },
        "resolution": { "type": "string", "enum": ["480p", "720p", "1080p"] },
        "videoSeconds": { "type": "number", "minimum": 2, "maximum": 10 },
        "generate_audio": { "type": "boolean" },
        "watermark": { "type": "boolean" },
        "referenceImages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" }
            },
            "required": ["url"]
          }
        },
        "referenceVideos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" }
            },
            "required": ["url"]
          }
        },
        "referenceAudios": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" }
            },
            "required": ["url"]
          }
        }
      },
      "required": ["baseUrl", "apiKey", "prompt"]
    }
  }
}
